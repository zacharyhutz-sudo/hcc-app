---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Dashboard">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
    <div class="bg-white border border-[#1b2a23]/5 p-8 shadow-sm">
      <h3 class="text-3xl mb-4 text-[#1b2a23]">Quick Actions</h3>
      <ul class="flex flex-col gap-4">
        <li><a href="/projects" class="bg-[#7ea493] text-white px-6 py-2 rounded-sm hover:opacity-90 transition-opacity block text-center">Manage Projects</a></li>
        <li><a href="/payments" class="bg-[#1b2a23] text-white px-6 py-2 rounded-sm hover:opacity-90 transition-opacity block text-center">View Payments Dashboard</a></li>
      </ul>
    </div>
    <div class="bg-white border border-[#1b2a23]/5 p-8 shadow-sm">
      <h3 class="text-3xl mb-4 text-[#1b2a23]">Recent Activity</h3>
      <p class="text-[#51645c]">Waiting for Unscripted data sync...</p>
    </div>
  </div>
</Layout>
